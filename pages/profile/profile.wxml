<view class="container">
  <view class="header" wx:if="{{!showContentList}}">
    <view class="avatar-section">
      <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"/>
        <text wx:else class="avatar-emoji">😋</text>
      </button>
      <view class="user-info">
        <text class="nickname">{{nickname}}</text>
        <view class="edit-btn" bindtap="onEditNickname">
          <text class="edit-icon">✏️</text>
          <text class="edit-text">编辑</text>
        </view>
      </view>
    </view>
  </view>

  <view class="header" wx:else>
    <view class="nav-bar">
      <view class="back-btn" bindtap="onBackToList">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">
        {{activeTab === 'posts' ? '我的发布' : activeTab === 'favorites' ? '我的收藏' : '我的点赞'}}
      </text>
      <view class="placeholder"></view>
    </view>
  </view>

  <view class="stats-section" wx:if="{{!showContentList}}">
    <view class="stat-item">
      <text class="stat-number">{{postCount}}</text>
      <text class="stat-label">分享</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{favoriteCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{likeCount}}</text>
      <text class="stat-label">点赞</text>
    </view>
  </view>

  <view class="menu-section" wx:if="{{!showContentList}}">
    <view class="menu-item" bindtap="onMyPosts">
      <text class="menu-icon">📝</text>
      <text class="menu-text">我的发布</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMyComments">
      <text class="menu-icon">💬</text>
      <text class="menu-text">我的评论</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMyFavorites">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMyLikes">
      <text class="menu-icon">👍</text>
      <text class="menu-text">我的点赞</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section" wx:if="{{!showContentList}}">
    <view class="menu-item" bindtap="onSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">❓</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="content-list" wx:if="{{showContentList}}">
    <view wx:for="{{contentList}}" wx:key="id" class="content-card">
      <view wx:if="{{activeTab === 'comments'}}" class="comment-post-title">
        <text class="post-label">评论于：</text>
        <text class="post-title-link">{{item.postTitle || '帖子'}}</text>
      </view>
      <view class="content-header">
        <text class="content-title" wx:if="{{activeTab !== 'comments'}}">{{item.title}}</text>
        <view wx:if="{{activeTab === 'comments'}}" class="comment-content">
          <text class="comment-text">{{item.content}}</text>
        </view>
        <view wx:if="{{activeTab === 'favorites'}}" class="content-remove" catchtap="onRemoveFavorite" data-id="{{item.id}}">
          <text>取消收藏</text>
        </view>
      </view>
      <text class="content-desc" wx:if="{{activeTab !== 'comments'}}">{{item.content}}</text>
      <view class="content-meta">
        <text class="content-time">{{item.createTime}}</text>
        <view class="content-stats" wx:if="{{activeTab !== 'comments'}}">
          <text class="stat">❤️ {{item.likes}}</text>
          <text class="stat">⭐ {{item.favorites}}</text>
          <text class="stat">💬 {{item.comments.length}}</text>
        </view>
      </view>
      <view class="card-click" bindtap="onContentTap" data-id="{{item.id || item.postId}}"></view>
    </view>
  </view>
</view>