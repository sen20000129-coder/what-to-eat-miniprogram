.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFF0D4 100%);
  display: flex;
  flex-direction: column;
}

/* 加载中 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
}

/* 内容滚动区域 */
.content-scroll {
  flex: 1;
  overflow-y: auto;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 20rpx 20rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.placeholder {
  width: 60rpx;
}

/* 作者信息 */
.author-section {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #fff;
  margin-bottom: 2rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #FFE4B5;
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.post-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 帖子内容 */
.post-content {
  background: #fff;
  padding: 24rpx 20rpx;
}

.post-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.4;
}

.post-text {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

/* 图片 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 20rpx;
  background: #fff;
}

.post-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.post-image.single {
  width: 100%;
  height: 500rpx;
}

/* 位置信息 */
.location-section {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  margin: 0 20rpx;
  border-radius: 16rpx;
}

.location-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-main {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E7D32;
}

.location-address {
  font-size: 24rpx;
  color: #4CAF50;
  margin-top: 4rpx;
}

.copy-hint {
  font-size: 22rpx;
  color: #4CAF50;
  background: rgba(255, 255, 255, 0.5);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 标签 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 2rpx;
}

.tag {
  padding: 10rpx 20rpx;
  background: #FFF8E7;
  color: #FF8E53;
  font-size: 26rpx;
  border-radius: 24rpx;
}

/* 互动区域 */
.actions-section {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
}

.action-icon {
  font-size: 44rpx;
}

.action-count {
  font-size: 24rpx;
  color: #999;
}

.action-label {
  font-size: 24rpx;
  color: #666;
}

.action-item.liked .action-count {
  color: #FF6B6B;
}

.action-item.favorited .action-icon {
  transform: scale(1.1);
}

.action-item.favorited .action-count {
  color: #FFA500;
}

.comment-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #FF6B6B;
  padding: 8rpx 16rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 8rpx;
}

.share-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}

/* 评论区域 */
.comments-section {
  background: #fff;
  padding: 24rpx 20rpx;
  min-height: 400rpx;
}

.comments-header {
  margin-bottom: 24rpx;
}

.comments-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.comments-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.comment-content {
  flex: 1;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 空评论 */
.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 底部占位 */
.bottom-placeholder {
  height: 120rpx;
}

/* 评论输入框 */
.comment-input-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
}

.submit-btn {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.submit-btn::after {
  border: none;
}
