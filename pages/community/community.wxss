.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFF0D4 100%);
  padding-bottom: 120rpx;
}

/* 头部导航 */
.header {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 40rpx 20rpx 20rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.placeholder {
  width: 60rpx;
}

/* 搜索栏 */
.search-section {
  padding: 20rpx;
  background: #fff;
}

.search-box {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ccc;
  border-radius: 50%;
}

.clear-icon {
  font-size: 20rpx;
  color: #fff;
}

/* 筛选区域 */
.filter-section {
  background: #fff;
  padding: 20rpx 0;
  margin-bottom: 2rpx;
}

.filter-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 20rpx 16rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.filter-hint {
  font-size: 24rpx;
  color: #999;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
}

.tag-item {
  background: #FFF0F0;
  color: #FF6B6B;
}

.tag-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
}

/* 帖子列表区域 */
.posts-section {
  padding: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.post-count {
  font-size: 24rpx;
  color: #999;
}

.posts-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.post-click-area {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 180rpx;
  z-index: 10;
}

/* 帖子头部 */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 2rpx solid #FFE4B5;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.post-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.location-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.location-icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.location-text {
  font-size: 22rpx;
  color: #4CAF50;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 16rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.post-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 图片 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.post-image.single {
  width: 100%;
  height: 400rpx;
}

/* 标签 */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  padding: 8rpx 16rpx;
  background: #FFF8E7;
  color: #FF8E53;
  font-size: 24rpx;
  border-radius: 16rpx;
}

/* 互动按钮 */
.post-actions {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid #F5F5F5;
  position: relative;
  z-index: 20;
}

.action-btn {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  position: relative;
  z-index: 20;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-count {
  font-size: 26rpx;
  color: #999;
}

.action-count.liked {
  color: #FF6B6B;
}

.action-text {
  font-size: 26rpx;
  color: #999;
}

/* 加载更多 */
.load-more,
.loading,
.no-more {
  text-align: center;
  padding: 40rpx 0;
}

.load-text,
.loading-text,
.no-more-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 发布按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.fab-text {
  font-size: 22rpx;
  color: #fff;
  margin-top: 4rpx;
}

/* 评论弹窗 */
.comment-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.comment-dialog {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.comment-dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.comment-dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.comment-dialog-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
}

.comment-dialog-close text {
  font-size: 28rpx;
  color: #666;
}

.comment-dialog-content {
  padding: 24rpx 32rpx;
}

.comment-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #F9F9F9;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.comment-hint {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.comment-dialog-footer {
  padding: 24rpx 32rpx;
}

.comment-submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
