.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFF0D4 100%);
  display: flex;
  flex-direction: column;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 20rpx 20rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.header-left,
.header-right {
  width: 120rpx;
}

.cancel-btn {
  font-size: 30rpx;
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.submit-btn {
  background: #FF6B6B;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  border: none;
  margin: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
}

/* 表单滚动区域 */
.form-scroll {
  flex: 1;
  overflow-y: auto;
}

.form-content {
  padding: 20rpx;
}

/* 表单项 */
.form-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 标题输入 */
.title-input {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.input-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 12rpx;
}

/* 内容输入 */
.content-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  padding: 16rpx 0;
}

/* 区域标签 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.label-hint {
  font-size: 24rpx;
  color: #999;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #FF6B6B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 20rpx;
  color: #fff;
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  border: 4rpx dashed #FFE4B5;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFF8E7;
}

.add-icon {
  font-size: 60rpx;
  color: #FF8E53;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #FF8E53;
  margin-top: 8rpx;
}

/* 位置信息 */
.location-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
}

.location-btn-icon {
  font-size: 24rpx;
}

.location-btn-text {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 500;
}

.location-inputs {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.input-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.location-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

/* 标签输入 */
.tag-input-area {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tag-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.add-tag-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}

.add-tag-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FFF0F0 0%, #FFE4E4 100%);
  border-radius: 24rpx;
}

.tag-item text {
  font-size: 26rpx;
  color: #FF6B6B;
}

.tag-remove {
  width: 32rpx;
  height: 32rpx;
  background: #FF6B6B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx !important;
  color: #fff !important;
}

/* 提示信息 */
.tips-section {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1976D2;
  display: block;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.5;
}
