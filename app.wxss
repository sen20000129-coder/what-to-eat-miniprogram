page {
  background-color: #FFF8E7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Microsoft YaHei', sans-serif;
}

/* 通用样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFF0D4 100%);
}

/* 按钮重置 */
button::after {
  border: none;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}
